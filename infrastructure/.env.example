# --- Infrastructure ---
POSTGRES_DB=tax_ocr
POSTGRES_USER=tax_ocr
POSTGRES_PASSWORD=tax_ocr_dev
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=tax-ocr-active

# --- Backend App (set before running go run ./cmd/...) ---
DATABASE_URL=postgres://tax_ocr:tax_ocr_dev@localhost:5432/tax_ocr?sslmode=disable
REDIS_ADDR=localhost:6379
MINIO_ENDPOINT=localhost:9000
JWT_SECRET=change_me_in_production
APP_ADDR=:8080

# --- External APIs ---
OPENAI_API_KEY=
GCV_API_KEY=

# --- LINE ---
LINE_CHANNEL_TOKEN=
LINE_CHANNEL_SECRET=

# --- Optional ---
REVIEWER_EXPIRE_MINUTES=30
MIGRATIONS_DIR=../database/migrations
